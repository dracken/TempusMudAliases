#ALIAS {gotoGith}
{
    #VARIABLE {githFound}{0};
    #VARIABLE {findGith}{1};
    #MATH githX 0;
    #MATH githY 0;
    #MATH githZ 0;
    gotoastral;
    #SH {<cfa>Okay!<099> Travelling to <FFF0>Gith<099>!};
    #DELAY {2}
    {
        #IF {!$travelerror}
        {
            #5 north;exits;
            #ACTION {^The Astral Plane}
            {
                #IF {$debug === 1}
                {
                    #SHOWME {<F0FF>Debug:<099> Astral Plane Action triggered.};
                };
                #IF {$findGith === 1 && !$isFighting}
                {
                    #IF {$debug === 1}
                    {
                        #SHOWME {<F0FF>Debug:<099> Find Gith is <cfa>ON<099>!};
                    };
                    #IF {$githX < 8}
                    {
                        #IF {$debug === 1}
                        {
                            #SHOWME {<F0FF>Debug:<099> Gith X = $githX};
                        };
                        #IF {$githFound === 0}
                        {
                            fly north;
                            #MATH githX $githX + 1;
                        };
                        #ELSE
                        {
                            enter island;
                            challenges area;
                        };
                        #IF {$githY < 8 && $githX == 7}
                        {
                            #MATH githX 0;
                            #IF {$debug === 1}
                            {
                                #SHOWME {<F0FF>Debug:<099> Gith Y = $githY};
                            };
                            #IF {$githFound === 0}
                            {
                                fly west;
                                #MATH githY $githY + 1;
                            };
                            #ELSE
                            {
                                enter island;
                                challenges area;
                            };
                            #IF {$githZ < 8 && $githY === 7}
                            {
                                #IF {$debug === 1}
                                {
                                    #SHOWME {<F0FF>Debug:<099> Gith Z = $githZ};
                                };
                                #IF {$githFound === 0}
                                {
                                    fly up;
                                    #MATH githZ $githZ + 1;
                                    #MATH githY 0;
                                    #MATH githX 0;
                                };
                                #ELSE
                                {
                                    enter island;
                                    challenges area;
                                };
                            };
                        };
                    };
                    #IF {$githZ === 8}
                    {
                        #SHOWME {<0F00>Warning!<099> Unable to locate the Githyanki Fortress!};
                        #VAR {findGith} {0};
                    };
                };
            };
        #SHOWME {<F0FF>Warning!<099> Attacked, ceasing search.};
        };
        #ELSE
        {
            resettravel;
        };
    };
}
{5}

