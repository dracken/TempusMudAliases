#ALIAS {helpShade}
{
    #SHOWME {<fca>************************<F0FF> Help Shade <fca>************************<099>};
    #SHOWME {<fca>gotoShadeRebel - To Rebel Leader From Tiltin<099>: };
    #SHOWME {    d;e;s;d;d;d;s;e;n;n;n;n;bash stone d;d;s;w;w;d;w;n;n;w;w;n;d;w;s;d;s;u;w};
    #SHOWME {<fca>gotoShadeSelset - To Selset from Rebel Leader<099>: e;d;n;u;e;bash cage n};
    #SHOWME {<fca>************************************************************<099>};
}
{5}

#ALIAS {gotoShadeRebel}
{
    where;
    #DELAY {2}
    {
        #IF {{$currentRoom} === {The Top of the Tower}}
        {
            #SH {<cfa>Okay!<099> Travelling to <FFF0>Shade Rebel<099>!};
            fly desdddsennnn;bash stone d;fly dswwdwnnwwndwsdsuw;
        };
        #ELSE
        {
