			#SH { <acf>|  <F0FF>4)<099> Intelligence       <F0FF>5)<099> Strength               <F0FF>6)<099> Wisdom                   <acf>|<099> };
			#SH { <acf>|  <F0FF>7)<099> Weapon Enhancer    <F0FF>8)<099> Weapon Specializer     <F0FF>9)<099> Weapon Un-Specializer    <acf>|<099> };
			#SH { <acf>| <F0FF>10)<099> The Gainer        <F0FF>11)<099> Electronics School                                                       <acf>|<099> };
			#SH { <acf>|                                                                              <acf>|<099> };
			#SH { <acf>└------------------------------------------------------------------------------┘<099> };
		};

		#ELSEIF {{"$travelInput1"} === {"guilds"} || {%1} === {5}}
		{
        		#SH { <acf>┌------------------------------------------------------------------------------┐<099> };
		        #SH { <acf>|                          <FF0F>Guilds Locations<099>                                    <acf>|<099> };
		        #SH { <acf>├------------------------------------------------------------------------------┤<099> };
		        #SH { <acf>|  <F0FF>1)<099> Barbarian         <F0FF>2)<099> Bard                    <F0FF>3)<099> Cleric (<FF00>Evil<099>)            <acf>|<099> };
			#SH { <acf>|  <F0FF>4)<099> Cleric (<F00F>Good<099>)     <F0FF>5)<099> Cyborg                  <F0FF>6)<099> Knight (<FF00>Evil<099>)            <acf>|<099> };
			#SH { <acf>|  <F0FF>7)<099> Knight (<F00F>Good<099>)     <F0FF>8)<099> Mage                    <F0FF>9)<099> Mercenary                <acf>|<099> };
			#SH { <acf>| <F0FF>10)<099> Monk             <F0FF>11)<099> Physic                 <F0FF>12)<099> Psionicist               <acf>|<099> };
			#SH { <acf>| <F0FF>13)<099> Ranger           <F0FF>14)<099> Thief                  <F0FF><099>                             <acf>|<099> };
			#SH { <acf>|                                                                              <acf>|<099> };
        		#SH { <acf>└------------------------------------------------------------------------------┘<099> };
		};

		#ELSEIF {{"$travelInput1"} === {"underdark"} || {%1} === {6}}
		{
			#SH { <acf>┌------------------------------------------------------------------------------┐<099> };
			#SH { <acf>|                        <007>Underdark<099>                                              <acf>|<099> };
			#SH { <acf>├------------------------------------------------------------------------------┤<099> };
			#SH { <acf>|  <F0FF>1)<099> Head Shrinker <F0FF>2)<099> Lizard Caverns  <F0FF>3)<099> Wyllowwood<099> };
			#SH { <acf>|                                                                              <acf>|<099> };
			#SH { <acf>└------------------------------------------------------------------------------┘<099> };
		};


		#ELSEIF {{"$travelInput1"} === {"all"} || {%1} === {7}}
		{
			#SH { <acf>┌------------------------------------------------------------------------------┐<099> };
			#SH { <acf>|                          <179> ALL Locations<099>                                      <acf>|<099> };
			#SH { <acf>├------------------------------------------------------------------------------┤<099> };
			#SH { <acf>|                                                                              <acf>|<099> };
			#SH { <acf>|                          <FF00>Under Construction<099>                                  <acf>|<099> };
			#SH { <acf>|                                                                              <acf>|<099> };
			#SH { <acf>└------------------------------------------------------------------------------┘<099> };
		};

		#ELSE {
			#SH { <FF00>Travel Warning:<099> The value '<fac>%1<099>' is not a valid travel destination. };
		}
	}
{4}

#ALIAS {travel} {
	#SH { <acf>┌------------------------------------------------------------------------------┐<099> };
	#SH { <acf>|                          <fca> Where To Travel<099>                                    <acf>|<099> };
	#SH { <acf>├------------------------------------------------------------------------------┤<099> };
	#SH { <acf>|                                                                              |<099> };
	#SH { <acf>|<099>               1) <F0FF>Past<099>      2) <afc>Future<099>      3) <fac>Planes<099>                          <acf>|<099> };
	#SH { <acf>|<099>               4) <FFF0>Trainers<099>  5) <FF0F>Guilds<099>      6) <007>Underdark<099>                       <acf>|<099> }; 
	#SH { <acf>|<099>                               7) <179>All<099>                                         <acf>|<099> };
	#SH { <acf>|                                                                              <acf>|<099> };
	#SH { <acf>└------------------------------------------------------------------------------┘<099> };

}
{5}

#NOP ----------------------------------------------------------------------------------------------
#NOP                                      Anchor Start Locations


#ACTION {^You are located: %1}
{
	#VAR {currentRoom} {%1};
}
{1}

#ALIAS {resettravel} {
	#VAR {travelerror}{0};
	#VAR {travelling}{0};
}
{5}

#ALIAS {gotohs} {
	fly;
	where;
	#DELAY {1} {
		#IF {{$currentRoom} === {$myStartingRoomName}}
		{
			#VAR {travelling} {1};
			directionsToHolySquare;
		};
		#ELSE {
			#SH {<FF00>Warning!<FBBB> The current starting room is <FF00>NOT<FBBB> your default start room '$myStartingRoomName'!};
			#VAR {travelerror} {1};
			#VAR {travelling} {0};
		}
	}
}
{5}

