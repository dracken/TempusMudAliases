			#SH { <acf>| <F0FF>31)<099> <FF00>Triskin Asylum<099>     <F0FF>32)<099> Virtual  World       <F0FF>33)<099>Zul’Dane                  <acf>|<099> };
			#SH { <acf>|                                                                              <acf>|<099> };
			#SH { <acf>└------------------------------------------------------------------------------┘<099> };
