			#CASE {"41"} { gotoUndermountain; };
			#CASE {"42"} { gotoWemicPlains; };
			#CASE {"43"} { gotoZhengisCastle; };
			#DEFAULT {
				#VAR {travelerror} {1};
				#SH {Invalid Destination Combination '<FF00>%1<099>' and '<FF00>%2<099>'};
				};
			};
		};

	#ELSEIF {{"$travelInput1"} === {"future"} || {%1} === {2}} {
		#SWITCH {"%2"} {
			#CASE {"1"} { gotoAPollutedVillage };
			#CASE {"2"} { gotoArcheologicalDig };
			#CASE {"3"} { gotoBlastedSwamp };
			#CASE {"4"} { gotoColony };
			#CASE {"5"} { gotoCybertechLabs };
			#CASE {"6"} { gotoCybertechPreparatorySchool };
			#CASE {"7"} { gotoDeathRow };
			#CASE {"8"} { gotoDracharnos };
			#CASE {"9"}  { gotoDrugDealer };
			#CASE {"10"} { gotoECJunkyard };
			#CASE {"11"} { gotoECMilitary };
			#CASE {"12"} { gotoECVamps };
			#CASE {"13"} { gotoECNuclearPower };
			#CASE {"14"} { gotoECPowerAndPlumbing };
			#CASE {"15"} { gotoECSecurityCompound };
			#CASE {"16"} { gotoECUniversity };
			#CASE {"17"} { gotoElectronicsSchool };
			#CASE {"18"} { gotoElectronicsShop };
			#CASE {"19"} { gotoFailFamilyLegacy };
			#CASE {"20"} { gotoFassanSlaveCompound };
			#CASE {"21"} { gotoGenCloneBioMechanicalLabs };
			#CASE {"22"} { gotoKiddieKandy };
			#CASE {"23"} { gotoKromguard };
			#CASE {"24"} { gotoLuxare };
			#CASE {"25"} { gotoMerquryCity };
			#CASE {"26"} { gotoNETWORKCommunicationsTower };
			#CASE {"27"} { gotoReinforcer };
			#CASE {"28"} { gotoRuinsOfHTOM };
			#CASE {"29"} { gotoRuinsOfTheSilverTower };
			#CASE {"30"} { gotoSimeonTheCybernetic };
			#CASE {"31"} { gotoTriskinAsylum };
			#CASE {"32"} { gotoVirtualWorldOfNETWORK };
			#CASE {"33"} { gotoZulDane };
			#DEFAULT {
	            #VAR {travelerror} {1};
	    #SH {Invalid Destination Combination '<FF00>%1<099>' and '<FF00>%2<099>'};
	        };
		};
	};

	#ELSEIF {{"$travelInput1"} === {"planes"} || {%1} === {3}} 
	{
		#SWITCH {"%2"} 
		{
			#CASE {"1"} { gotoAbyssUnholyModrian; };
			#CASE {"2"} { gotoAmoria; };
			#CASE {"3"} { gotoAvernusHell; };
			#CASE {"4"} { gotoElementalPlaneOfAir; };
			#CASE {"5"} { gotoElementalPlaneOfEarth; };
