			#CASE {"10"} { gotoElementalPlaneOfWater; };
			#CASE {"11"} { gotoLuniaHeaven; };
			#CASE {"12"} { gotoImmoth; };
		   	#CASE {"13"} { gotoCastleMahlhevik; };
			#CASE {"14"} { gotoGith; };
		    #DEFAULT 
			{
				#VAR {travelerror} {1};
				#SH {Invalid Destination Combination '<FF00>%1<099>' and '<FF00>%2<099>'};
			};
		};
	};

		#ELSEIF {{"$travelInput1"} === {"trainers"} || {%1} === {4}} {
			#SWITCH {"%2"} {
				#CASE {"1"} { gotoCharismaTrainer;};
				#CASE {"2"} { gotoConstitutionTrainer; };
				#CASE {"3"} { gotoDexterityTrainer; };
				#CASE {"4"} { gotoIntelligenceTrainer; };
				#CASE {"5"} { gotoStrengthTrainer; };
				#CASE {"6"} { gotoWisdomTrainer; };
				#CASE {"7"} { gotoWeaponEnhancer };
				#CASE {"8"} { gotoWeaponSpecializer };
				#CASE {"9"} { gotoWeaponUnSpecializer };
				#CASE {"10"} { gotoGainer };
				#CASE {"11"} { gotoElectronicsSchool };
				#DEFAULT {
					#VAR {travelerror} {1};
			#SH {Invalid Destination Combination '<FF00>%1<099>' and '<FF00>%2<099>'};
				};
			};
		};

		#ELSEIF {{"$travelInput1"} === {"guilds"} || {%1} === {5}} {
			#SWITCH {"%2"} {
				#CASE {"1"} { gotoBarbarianGuildmsater;};
				#CASE {"2"} { gotoBardGuildmaster; };
				#CASE {"3"} { gotoClericEvilGuildmaster; };
				#CASE {"4"} { gotoClericGoodGuildmaster; };
				#CASE {"5"} { gotoCyborgGuildmaster; };
				#CASE {"6"} { gotoKnightEvilGuildmaster; };
				#CASE {"7"} { gotoKnightGoodGuildmaster; };
				#CASE {"8"} { gotoMageGuildmaster; };
				#CASE {"9"} { gotoMercenaryGuildmaster; };
				#CASE {"10"} { gotoMonkGuildmaster; };
				#CASE {"11"} { gotoPhysicGuildmaster; };
				#CASE {"12"} { gotoPsionicistGuildmaster; };
				#CASE {"13"} { gotoRangerGuildmaster; };
				#CASE {"14"} { gotoThiefGuildmaster; };
				#DEFAULT {
					#VAR {travelerror} {1};
			#SH {Invalid Destination Combination '<FF00>%1<099>' and '<FF00>%2<099>'};
				};
			};
		};

		#ELSEIF {{"$travelInput1"} === {"underdark"} || {%1} === {6}} {
			#SWITCH {"%2"} {
				#CASE {"1"} { gotoHeadShrinker };
				#CASE {"2"} { gotoLizardCaverns };
				#CASE {"3"} { gotoWyllowwood };
				#DEFAULT {
					#VAR {travelerror} {1};
			#SH {Invalid Destination Combination '<FF00>%1<099>' and '<FF00>%2<099>'};
				};
			};
		};


		#ELSEIF {{"$travelInput1"} === {"all"} || {%1} === {7}} {
			#NOP //Todo - Use the different lists to formulate a list of available directions
		};

		#ELSE {
			#VARIABLE {travelerror} {1};
		#SH {Invalid Planar Destination '<FF00>%1<099>'};
		};
	}
	{3}

	#ALIAS {travel %1} {
		#FORMAT {travelInput1} {%1} {%l};
		#FORMAT {travelInput1Upper} {%1} {%u};
		#IF {debug} {
			#SH {Travel Destination: '$travelInput1'};
			#SH {Travel Destination Upper: '$travelInput1Upper};
		};
	        #IF {{"$travelInput1"} === {"help"} || {"$travelInput1"} === {"?"}}
		{
	            	#SH { <afc>******************************************************************************************<099> };
	            	#SH { <afc>*                                Directions Help!                                        *<099> };
	            	#SH { <afc>******************************************************************************************<099> };
	            	#SH { <afc>*<099>                                                                                        <afc>*<099>};
	            	#SH { <afc>*<F0FF> Usage:<099> travel <plane> <zone>                                                           <afc>*<099>};
	            	#SH { <afc>*<FFF0> Example:<099> travel planes 9                                                               <afc>*<099>};
	            	#SH { <afc>*<099>      Travel to the Elemental Plane of Smoke                                            <afc>*<099>};
	            	#SH { <afc>*<FFF0> Example:<099> travel 2 15                                                                   <afc>*<099>};
	            	#SH { <afc>*<099>      Travel to the Future's EC Universty                                               <afc>*<099>};
	            	#SH { <afc>*<099>                                                                                        <afc>*<099>};
	            	#SH { <afc>*<FF0F> Recommendations:<099> Make an alias in your own scriping config for locations you use       <afc>*<099> };
	            	#SH { <afc>*<099>    regularly!                                                                          <afc>*<099> };
	        	#SH { <afc>******************************************************************************************<099> };
	        };

		#ELSEIF {{"$travelInput1"}  === {"past"} || {%1} === {1}}
		{
			#SH { <acf>┌------------------------------------------------------------------------------┐<099> };
			#SH { <acf>|                           <F0FF>Past Locations<099>                                     <acf>|<099> };
			#SH { <acf>├------------------------------------------------------------------------------┤<099> };
			#SH { <acf>|  <F0FF>1)<099> Abandoned Keep       <F0FF>2)<099> Old Monastery        <F0FF>3)<099> Castle Slivendark        <acf>|<099> };
			#SH { <acf>|  <F0FF>4)<099> Chessboard of Araken <F0FF>5)<099> Dismal Delve         <F0FF>6)<099> Draconians and Highlords <acf>|<099> };
			#SH { <acf>|  <F0FF>7)<099> Duke Araken          <F0FF>8)<099> Elven Village        <F0FF>9)<099> Forgotten Valley         <acf>|<099> };
			#SH { <acf>| <F0FF>10)<099> Font of Modrian     <F0FF>11)<099> Frozen Tundras      <F0FF>12)<099> Glacial Rift             <acf>|<099> };
			#SH { <acf>| <F0FF>13)<099> Great Pyramid       <F0FF>14)<099> Guiharian Festival  <F0FF>15)<099> Halfling Village         <acf>|<099> };
			#SH { <acf>| <F0FF>16)<099> Harpell House       <F0FF>17)<099> High Tower of Magic <F0FF>18)<099> Hill Giant Steading      <acf>|<099> };
			#SH { <acf>| <F0FF>19)<099> Hobgoblins          <F0FF>20)<099> Holy Grail          <F0FF>21)<099> Istan                    <acf>|<099> };
			#SH { <acf>| <F0FF>22)<099> Kobold Tunnels      <F0FF>23)<099> Caves of Learander  <F0FF>24)<099> Crystal Fortress         <acf>|<099> };
			#SH { <acf>| <F0FF>25)<099> Malevolent Circle   <F0FF>26)<099> Mavernal            <F0FF>27)<099> Neverwhere               <acf>|<099> };
			#SH { <acf>| <F0FF>28)<099> Ogre Encampment     <F0FF>29)<099> Old Thalos          <F0FF>30)<099> Pit Fiend                <acf>|<099> };
			#SH { <acf>| <F0FF>31)<099> Pool of Evil        <F0FF>32)<099> Reed Swamp/Lizards  <F0FF>33)<099> Sewers of Modrian        <acf>|<099> };
			#SH { <acf>| <F0FF>34)<099> Shade               <F0FF>35)<099> Silver Tower        <F0FF>36)<099> Solace Cove              <acf>|<099> };
			#SH { <acf>| <F0FF>37)<099> Skullport (River)   <F0FF>38)<099> Temple of Ancients  <F0FF>39)<099> Tower of Renegade Mage   <acf>|<099> };
			#SH { <acf>| <F0FF>40)<099> Treetops of Arachna <F0FF>41)<099> Undermountain       <F0FF>42)<099> Wemic Plains             <acf>|<099> };
			#SH { <acf>| <F0FF>43)<099> Zhengi's Castle                                                          <acf>|<099> };
			#SH { <acf>|                                                                              <acf>|<099> };
			#SH { <acf>└------------------------------------------------------------------------------┘<099> }; 
		};

		#ELSEIF {{"$travelInput1"} === {"future"} || {%1} === {2}}
		{
			#SH { <acf>┌------------------------------------------------------------------------------┐<099> };
			#SH { <acf>|                           <afc>Future Locations<099>                                   <acf>|<099> };
			#SH { <acf>├------------------------------------------------------------------------------┤<099> };
