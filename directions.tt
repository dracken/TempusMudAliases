			#CASE {"28"} { gotoOgreEncampment; };
			#CASE {"29"} { gotoOldThalos; };
			#CASE {"30"} { gotoPitFiend; };
			#CASE {"31"} { gotoPoolOfEvil; };
			#CASE {"32"} { gotoReedSwamp; };
			#CASE {"33"} { gotoSewersOfModrian; };
			#CASE {"34"} { gotoShade; };
			#CASE {"35"} { gotoSilverTower; };
			#CASE {"36"} { gotoSolaceCove; };
			#CASE {"37"} { gotoSkullport; };
			#CASE {"38"} { gotoTempleOfAncients; };
			#CASE {"39"} { gotoTowerOfTheRenegadeMage; };
