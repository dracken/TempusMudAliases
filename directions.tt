#ALIAS {travel %1 %2} {
	#FORMAT {travelInput1} {%1} {%l};

	#IF {{"$travelInput1"}  === {"past"} || {%1} === {1}} 
	{
		#SWITCH {"%2"} {
			#CASE {"1"} { gotoAbandonedKeep; };
			#CASE {"2"} { gotoOldMonastery; };
		    #CASE {"3"} { gotoCastleSlivendark; };
			#CASE {"4"} { gotoChessboardOfAraken; };
