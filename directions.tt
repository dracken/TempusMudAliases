#NOP ----- vvvv EDIT THESE VARS ONLY! vvvv -----

#VAR {myStartingRoomName} {The Beginning of Misery};
#ALIAS {directionsToHolySquare} {fly n;look modrian;fly nn};
#ALIAS {directionsToStarPlaza} {fly n;look ec};
#ALIAS {directionsToSlaveSquare} {fly n;look skullport};
#ALIAS {directionsToAstralManse} {fly n;look astral};

#NOP ----- ^^^^ EDIT THESE VARS ONLY! ^^^^ -----

